
<div class="container mt-5">
  <h3 class="mb-5 text-center card-film text-white rounded-4">Ajouter un nouveau genre</h3>
<%= simple_form_for(@list) do |f| %>

  <div class="form-inputs">
    <%= f.input :name, class: "name-input" %>
    <%= f.input :photo, as: :file %>
  </div>

  <div class="form-actions">
    <%= f.button :submit, class: "text-white btn btn-secondary" %>
  </div>
<% end %>
  <div class="mt-5">
    <%= link_to "Retourner à la liste des genres de film", lists_path, class: "btn btn-outline-danger text-decoration-none rounded-pill"%>
  </div>
</div>
