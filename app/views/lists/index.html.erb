<%= render "nav" %>
<div class= "banner mb-5">
<h1 class="fw-bold fs-1">Liste des genres de film</h1>
</div>

<div class="container">
 <div class="list-genre">
    <div>
      <p class="fs-3" >Ma liste</p>
    </div>

    <div class="d-flex flex-wrap justify-content-evenly">
        <% @lists.each do |list|%>
          <div class="card-film rounded-5 mb-5" style="width: 18rem;">
            <div class="card-body">
              <ul class="list-group list-group-flush">
                <%= link_to list.name, list_path(list), class: "text-decoration-none fs-3 text-white text-center fw-bold"%>
              </ul>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
